---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CV | Steven Glass">
  <section class="section">
    <h1>CV</h1>
    <p>
      Add your CV PDF later in <code>public/</code>. For now, this is a placeholder.
    </p>

    <a class="button" href="/cv.pdf" download>Download CV</a>

    <div class="card" style="margin-top: 1rem;">
      <p class="muted">
        Once you add your file as <code>public/cv.pdf</code>, it can also be embedded here.
      </p>
    </div>
  </section>
</BaseLayout>