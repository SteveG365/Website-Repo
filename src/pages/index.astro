---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Steven Glass | Portfolio">
  <section class="hero">
    <h1>Steven Glass</h1>
    <p>Machine Learning and Data Science Portfolio</p>
    <p>
      Welcome to my portfolio website. This site showcases selected machine
      learning, data science, and research-oriented projects, along with blog
      posts and my CV.
    </p>

    <a class="button" href="/projects">View Projects</a>
    <a class="button secondary" href="/cv">View CV</a>
  </section>

  <section class="section">
    <h2>Featured Projects</h2>
    <div class="grid">
      <article class="card">
        <h3>Variational Autoencoder Project</h3>
        <p class="muted">
          Placeholder for a project exploring variational autoencoders,
          generative modelling, and latent representations.
        </p>
      </article>

      <article class="card">
        <h3>Quantum State Tomography Project</h3>
        <p class="muted">
          Placeholder for a project on machine learning methods for quantum
          state reconstruction and physically valid inference.
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <h2>Latest Writing</h2>
    <div class="card">
      <h3>Welcome Post</h3>
      <p class="muted">
        A blog section is included from the start and can later be expanded
        with technical posts, project reflections, and write-ups.
      </p>
      <a href="/blog">Go to Blog</a>
    </div>
  </section>
</BaseLayout>