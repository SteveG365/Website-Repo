---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";

const projects = await getCollection("projects");

const featuredProjects = projects
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const posts = await getCollection("blog");

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const latestPost = sortedPosts[0];
---

<BaseLayout title="Steven Glass | Portfolio">
  <section class="hero">
    <h1>Steven Glass</h1>
    <p>Machine Learning and Data Science Portfolio</p>
    <p>
      Welcome to my portfolio website. This site showcases selected machine
      learning, data science, and research-oriented projects, along with blog
      posts and my CV.
    </p>

    <a class="button" href="/projects">View Projects</a>
    <a class="button secondary" href="/cv">View CV</a>
  </section>

  <section class="section">
    <h2>Featured Projects</h2>

    <div class="grid">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <!-- 🔥 Latest Blog Post -->
  <section class="section">
    <h2>Latest Writing</h2>

    {latestPost && (
      <div class="card">
        <h3>{latestPost.data.title}</h3>

        <p class="muted">
          {latestPost.data.pubDate.toLocaleDateString()}
        </p>

        <p class="muted">
          {latestPost.data.description}
        </p>

        <a class="button secondary" href={`/blog/${latestPost.id}`}>
          Read Post
        </a>
      </div>
    )}
  </section>
</BaseLayout>